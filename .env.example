# Copy to .env for local demos.
# Do not commit real values.

# ngrok
NGROK_AUTHTOKEN=

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=

# Optional first-pass manual token demo
GITHUB_TOKEN=

# Slack app credentials
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/integrations/google/oauth/callback

# Optional first-pass manual Google token demo
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Local demo host. JIDO_GITHUB_DEMO_PORT is kept as a temporary alias.
JIDO_CONNECT_DEMO_PORT=4000
JIDO_GITHUB_DEMO_PORT=4000
JIDO_CONNECT_DEMO_SECRET_DIR=
JIDO_CONNECT_PUBLIC_BASE_URL=
